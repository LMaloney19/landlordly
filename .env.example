# From Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# After setting env vars:
# 1. Copy this file to .env.local
# 2. Run migrations in the SQL Editor (in order):
#    - supabase/migrations/20250515000000_properties.sql
#    - supabase/migrations/20250515100000_rent_payments.sql
#    - supabase/migrations/20250515200000_tenants.sql
#    - supabase/migrations/20250515300000_maintenance_requests.sql
#    - supabase/migrations/20250515400000_documents.sql
#    - supabase/migrations/20250515500000_property_structured_address.sql
#    - supabase/migrations/20250515600000_property_units.sql
# 3. Enable Email auth under Authentication → Providers
