# From Supabase: Project Settings → API (or Connect dialog)
# URL must be ONLY the project root — no /auth/v1 or /rest/v1 suffix
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# anon public key (starts with eyJ...) — not service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# After setting env vars:
# 1. Copy this file to .env.local
# 2. Run migrations in the SQL Editor (in order):
#    - supabase/migrations/20250515000000_properties.sql
#    - supabase/migrations/20250515100000_rent_payments.sql
#    - supabase/migrations/20250515200000_tenants.sql
#    - supabase/migrations/20250515300000_maintenance_requests.sql
#    - supabase/migrations/20250515400000_documents.sql
#    - supabase/migrations/20250515500000_property_structured_address.sql
#    - supabase/migrations/20250515600000_property_units.sql
#    - supabase/migrations/20250516060000_rent_reminder_emails.sql
#    - supabase/migrations/20250516070000_document_unit_tenant.sql
#    - supabase/migrations/20250516080000_document_category_other.sql
# 3. Enable Email auth under Authentication → Providers

# Rent reminder emails (Resend + daily cron on Vercel)
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=Landlordly <onboarding@resend.dev>
# Supabase service role (Project Settings → API) — server/cron only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Random secret; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate-a-long-random-string
# Production app URL for email links
NEXT_PUBLIC_APP_URL=https://landlordly-ivory.vercel.app
